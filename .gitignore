node_modules
dist
dist-ssr
.DS_Store
*.local
.vite

# Nuxt build artifacts
.nuxt
.output
.nitro
.cache

# _archive/ — the 11 MB data.js is generated (regenerable from CSVs via
# build_data.py); exclude it from history to keep the repo small. The rest of
# the archive (source + docs) is committed for reference.
_archive/data.js
# Python bytecode that drifted into the archive.
_archive/scripts/__pycache__/

# legacy data sources — replaced by public/data/*.json
# keep them out of the repo; regenerate via `npm run data:convert`
data.js
pym_data.js

# Raw source data — NOT committed. The repo ships the built data.js instead;
# regenerate via `python scripts/build_data.py` after any CSV/xlsx change. (STATUS.md §6)
data/con-bill-*.csv
data/con-pym-*.csv
data/dda-*.csv
data/ddi-*.csv
data/constant-scheme-info.xlsx
data/contribution-allocation.xlsx

# Embedded PGlite database (regenerated from CSVs via `npm run reseed`).
data/.pglite/

# Stray files carried over from a separate Vite project — never commit. (STATUS.md §5.4)
data/CLAUDE.md
data/SPEC_*.md
data/.gitignore
data/image.png
scripts/image_to_excel.py

# Merge backup. (STATUS.md §6)
index-old.html

# data/data-source/ — Oracle data-collection tool (PowerShell). See data/data-source/README.md.
# .env holds live DB credentials — NEVER commit. Copy .env.example -> .env to set up.
data/data-source/.env

# Runtime outputs of Run-StatisticQueries.ps1: per-run CSVs (data/temp), transcript
# logs (data/log), and the daily zip (data/*.zip). Regenerate by running the script.
# Directory structure is preserved via .gitkeep so the script's output dirs exist.
data/data-source/data/temp/*
!data/data-source/data/temp/.gitkeep
data/data-source/data/log/*
!data/data-source/data/log/.gitkeep
data/data-source/data/*.zip

# Python bytecode cache (from scripts/test_build_data.py). Never commit.
__pycache__/
*.pyc

# jsdom smoke scratch dir (iter-02 verification harness). Not part of the app.
.smoke/
